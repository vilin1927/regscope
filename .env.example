# Supabase — get from Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI — for AI regulation scanning, risk analysis, recommendations
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2

# Resend — for newsletter email delivery
RESEND_API_KEY=re_...
RESEND_DOMAIN=complyradar.de

# Stripe — payment processing
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_INITIAL=price_...
STRIPE_PRICE_RECURRING=price_...

# Admin — comma-separated email addresses for admin access
ADMIN_EMAIL=admin@example.com
ADMIN_API_KEY=your-admin-api-key-here
